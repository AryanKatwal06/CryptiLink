# CryptiLink Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env with real values

# App
APP_ENV=
RAZORPAY_MODE=test

# Render Backend
API_BASE_URL=
RENDER_SERVICE_URL=
PORT=10000
NODE_ENV=development

# Neon PostgreSQL
DATABASE_URL=
DATABASE_URL_UNPOOLED=
DATABASE_URL_DEV=
DATABASE_URL_DEV_UNPOOLED=
DATABASE_URL_STAGING=
DATABASE_SHADOW_URL=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Firebase
FIREBASE_PROJECT_ID=

# Razorpay (TEST MODE ONLY)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# PostHog
POSTHOG_API_KEY=
POSTHOG_HOST=

# Android Build
ANDROID_KEYSTORE_FILE=
ANDROID_KEY_ALIAS=
ANDROID_STORE_PASSWORD=
ANDROID_KEY_PASSWORD=
