# CryptiLink Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env with real values

# App
APP_ENV=

# Render Backend
API_BASE_URL=
RENDER_SERVICE_URL=
PORT=10000
NODE_ENV=development

# Neon PostgreSQL
DATABASE_URL=
DATABASE_URL_UNPOOLED=
DATABASE_URL_DEV=
DATABASE_URL_DEV_UNPOOLED=
DATABASE_URL_STAGING=
DATABASE_SHADOW_URL=


# Firebase
FIREBASE_PROJECT_ID=

# Razorpay (TEST MODE ONLY)

# PostHog
POSTHOG_API_KEY=
POSTHOG_HOST=

# Android Build
ANDROID_KEYSTORE_FILE=
ANDROID_KEY_ALIAS=
ANDROID_STORE_PASSWORD=
ANDROID_KEY_PASSWORD=

# ── Hardcoded Key Fallbacks (REQUIRED FOR PRODUCTION) ───────
# Shared key for AES-256-GCM settlement batch encryption
# Must match the bank server's key. Prototype uses a fallback if empty.
SETTLEMENT_AES_KEY=

# Secret key for SQLCipher database encryption on the merchant device.
# In production, this should be derived from device hardware keystore.
MERCHANT_DB_KEY=
