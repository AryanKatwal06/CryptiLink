# URL of the Bank Server API
VITE_BANK_SERVER_URL=http://localhost:3000/api/v1

# Dashboard API Key (must match DASHBOARD_API_KEY on the bank server)
VITE_DASHBOARD_API_KEY=your_dashboard_secret_key

# PostHog settings for querying
VITE_POSTHOG_PROJECT_ID=your_project_id
VITE_POSTHOG_PERSONAL_API_KEY=your_personal_api_key
