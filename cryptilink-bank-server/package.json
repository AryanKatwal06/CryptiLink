{
  "name": "cryptilink-bank-server",
  "version": "1.0.0",
  "description": "CryptiLink Phase 1 — Mock Bank Server & HSM Key Engine for offline-capable payment protocol",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest --testPathPattern='(?<!integration)\\.' --forceExit",
    "test:integration": "jest --testPathPattern='integration' --forceExit --detectOpenHandles",
    "migrate": "ts-node src/db/migrate.ts",
    "seed": "ts-node scripts/seed.ts",
    "generate-keys": "ts-node scripts/generate-bank-keys.ts",
    "demo": "ts-node scripts/demo.ts"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pg": "^8.12.0",
    "posthog-node": "^5.38.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
