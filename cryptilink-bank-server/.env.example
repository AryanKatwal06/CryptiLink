# ═══════════════════════════════════════════════════════════════
# CryptiLink Bank Server — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.

# ── Server ──────────────────────────────────────────────────────
PORT=3000

# ── Database ────────────────────────────────────────────────────
# Local Docker Postgres (matches docker-compose.yml in project root):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cryptilink

# For Neon free tier (when deploying):
# DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/cryptilink?sslmode=require

# ── Bank Keypair Paths ──────────────────────────────────────────
# ECDSA prime256v1 (secp256r1) keypair — the root of trust.
# If these files don't exist on startup, the server will generate
# a new keypair and write to these paths.
BANK_PRIVATE_KEY_PATH=./keys/bank_private.pem
BANK_PUBLIC_KEY_PATH=./keys/bank_public.pem

# ── Security Caps (informational — hardcoded as constants) ──────
# These are NOT configurable via env vars by design.
# They are hardcoded in src/config/index.ts to prevent tampering:
#   MAX_OFFLINE_TX_AMOUNT   = 200   (₹200 per single offline tx)
#   MAX_OFFLINE_CUMULATIVE  = 500   (₹500 total before cert refresh)
#   INITIAL_LIQUID_BALANCE  = 10000 (₹10,000 mock starting balance)
